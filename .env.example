# Propr API credentials — get yours at https://app.propr.xyz/settings (Developer tab)
# IMPORTANT: copy this file to .env and fill your real values. NEVER commit .env

PROPR_API_KEY=pk_live_your_key_here

# Optional: hardcode your accountId to skip auto-detection
# Find it in the URL of your trading page: app.propr.xyz/account/XXXXXX/trade
PROPR_ACCOUNT_ID=
